<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <Button
        android:id="@+id/botonVolver"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:layout_margin="12dp"
        android:text="← Volver"
        android:textSize="13sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/fondo_boton_secundario"
        android:paddingHorizontal="16dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/botonVolver">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alarmas y recordatorios"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="24dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/botonNuevaMedicamento"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="💊 Medicamento"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/fondo_boton_principal"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/botonNuevoRecordatorio"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="📅 Recordatorio"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/fondo_boton_principal"
                    android:layout_marginStart="8dp"/>

            </LinearLayout>

            <TextView
                android:id="@+id/textoVacio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No hay alarmas configuradas"
                android:textSize="16sp"
                android:textColor="#AAAAAA"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/contenedorAlarmas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>