<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#1A1A2E">

    <TextView
        android:id="@+id/textoNivel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nivel 1"
        android:textSize="20sp"
        android:textColor="#AAAAAA"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/textoProgreso"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1 / 5"
        android:textSize="18sp"
        android:textColor="#AAAAAA"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/textoContador"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/textoOperacion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cargando..."
        android:textSize="52sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="48dp"/>

    <EditText
        android:id="@+id/campoRespuesta"
        android:layout_width="200dp"
        android:layout_height="72dp"
        android:inputType="numberSigned"
        android:textSize="32sp"
        android:textColor="#000000"
        android:background="@drawable/fondo_campo"
        android:gravity="center"
        android:hint="?"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/botonConfirmar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="CONFIRMAR"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/fondo_boton_principal"/>

</LinearLayout>