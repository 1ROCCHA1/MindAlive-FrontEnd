<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <Button
        android:id="@+id/botonVolver"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:layout_margin="12dp"
        android:text="← Volver"
        android:textSize="13sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/fondo_boton_secundario"
        android:paddingHorizontal="16dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/botonVolver">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Centro de control"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Actividad en juegos"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#5B8DEF"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/contenedorJuegos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gráfica de bienestar"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#5B8DEF"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/contenedorBienestar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Actividades de hoy"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#5B8DEF"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/contenedorActividades"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estado reciente"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#5B8DEF"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/textoEstadoReciente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cargando..."
                android:textSize="15sp"
                android:textColor="#CCCCCC"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resumen semanal"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#5B8DEF"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/botonResumen"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="📊 Generar resumen de la semana"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/fondo_boton_principal"
                android:layout_marginBottom="16dp"/>

            <ProgressBar
                android:id="@+id/progressResumen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/textoResumen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="15sp"
                android:textColor="#CCCCCC"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>