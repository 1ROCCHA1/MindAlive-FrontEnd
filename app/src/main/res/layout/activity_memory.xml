<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp">

        <TextView
            android:id="@+id/textoNivel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nivel 1"
            android:textSize="20sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/textoInstruccion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cargando..."
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/textoContador"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/textoParejas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Parejas: 0 / 0"
            android:textSize="18sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:id="@+id/contenedorModo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>

        <GridLayout
            android:id="@+id/gridCartas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:useDefaultMargins="false"/>

    </LinearLayout>

    <Button
        android:id="@+id/botonVolver"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:text="← Volver"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/fondo_boton_secundario"
        android:paddingHorizontal="24dp"/>

</FrameLayout>