<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="MindAlive"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MindAlive"
        android:usesCleartextTraffic="true">

        <activity android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".LoginActivity" android:exported="false"/>
        <activity android:name=".RegistroActivity" android:exported="false"/>
        <activity android:name=".PantallaMayorActivity" android:exported="false"/>
        <activity android:name=".PantallaCuidadorActivity" android:exported="false"/>
        <activity android:name=".PantallaJuegosActivity" android:exported="false"/>
        <activity android:name=".SimonActivity" android:exported="false"/>

    </application>

</manifest>